# Copy to `.env` and fill in. Never commit the real .env.
#
# The app is model-agnostic: pick ANY mainstream model by setting LLM_MODEL /
# EMBED_MODEL to a LiteLLM model string, then provide that provider's API key
# under its standard environment-variable name (LiteLLM reads it from there).

# --- Model selection (LiteLLM model strings) ---
# Examples:
#   openai/gpt-4o-mini                          (needs OPENAI_API_KEY)
#   gemini/gemini-2.0-flash                     (needs GEMINI_API_KEY)
#   anthropic/claude-3-5-sonnet-20241022        (needs ANTHROPIC_API_KEY)
#   mistral/mistral-large-latest                (needs MISTRAL_API_KEY)
#   groq/llama-3.3-70b-versatile                (needs GROQ_API_KEY)
#   deepseek/deepseek-chat                      (needs DEEPSEEK_API_KEY)
#   ollama/llama3                               (local; no key, set OLLAMA base if remote)
LLM_MODEL=gemini/gemini-2.0-flash
EMBED_MODEL=gemini/text-embedding-004

# --- Provider API keys (set only the ones you use) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=

# --- Optional overrides (defaults shown) ---
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
# TOP_K=6
# AGENT_MAX_STEPS=6
